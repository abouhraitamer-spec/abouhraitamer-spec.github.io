
<!DOCTYPE html>
<html lang="ca">
    <!--lang=language, la llengua que utilitza el document-->
<head> <!--JS-->
    <meta charset="UTF-8">
    <!--Meta = metainformacio, que es info sobre la pagina web. 
    Charset = conjunt se caracters que utilitzem 
    UTF-8 = unicode transformation format de 8 bits que permet accents, dieresei,ñ,ç, permet mes d'un millio de caracters entre ells chinese, arabic, etc...-->
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!--Aquesta liniea adapta la pagina web a la pantalla del dispositiu, device-width.-->
    <title>Reconeixement de Veu amb Anàlisi de Sentiments</title>
    <!--Titul de la pestaña-->
    <style> /*CSS,es com la decoració de la casa*/
        /* etiquetahtm{propietat1:valor1;propietat2:valor2;propietat3:valor3;}
        (etiquetahtml)El body=contingut de la pagina. 
        (propietat)Font-family=tipos de lletra, buscara Arial(valor) i si no ho troba buscara qualsevol sans-serif
        Hi ha 3 grups de lletres que son serif, sans-serif i monocode.
        ...  */
        body {
            font-family: Arial, sans-serif;
            max-width: 800px;
            /*Amplada maxima*/
            margin: 0 auto;
            /*margin=Marge exterior*/
            padding: 20px;
            /*padding=Marge interior*/
        }
        /*Tant com margin i padding poden tenir 5 propietats de pixels
        0 auto: 0 adalt i abaix i auto dreta esquerra
        1 numero de px: afectara a tot els marges
        2 numeros de px: primer numero afecta adalt y abaix, el segon dreta esquerra
        3 numeros de px: primer numero afecta adalt, el segon dreta esquerra, terçer numero abaix
        4 numeros de px: primer numero afecta adalt, el segon dreta , terçer numero abaix, quart numero esquerra*/
        
        button {
            padding: 10px 20px;
            font-size: 16px;
            cursor: pointer;
            margin-bottom: 20px;
        }
        
        .status {
            padding: 10px;
            margin: 10px 0;
            border-radius: 5px;
        }
        
        .sentiment-box {
            padding: 15px;
            margin-top: 20px;
            border-radius: 5px;
            font-weight: bold;
        }
        
        .positiu {
            background-color: #d4edda;
            color: #155724;
        }
        
        .negatiu {
            background-color: #f8d7da;
            color: #721c24;
        }
        
        .neutral {
            background-color: #e2e3e5;
            color: #383d41;
        }
    </style>
</head>
<body>

<h2>Prova de reconeixement de veu</h2>
<button onclick="start()">Parla</button>

<div class="status" id="estat">Esperant...</div>

<p><strong>Text reconegut:</strong></p>
<div id="resultat"></div>

<p><strong>Anàlisi de sentiments:</strong></p>
<div class="sentiment-box neutral" id="sentiment">
    Esperant text per analitzar...
</div>

<script>
const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
const recognition = new SpeechRecognition();
recognition.lang = "ca-ES";

// DICCIONARI SIMPLIFICAT (només 10 paraules)
const diccionariSentiments = {
    // Paraules positives (5 paraules)
    "bo": 2,
    "bé": 2,
    "content": 2,
    "feliç": 2,
    "fantàstic": 3,
    
    // Paraules negatives (5 paraules)
    "dolent": -2,
    "malament": -2,
    "trist": -2,
    "horrible": -3,
    "problema": -1
};

function analitzarSentiment(text) {
    const paraules = text.toLowerCase().split(/\s+/);
    let puntuacio = 0;
    let paraulesTrobades = [];
    
    for (const paraula of paraules) {
        if (diccionariSentiments.hasOwnProperty(paraula)) {
            puntuacio += diccionariSentiments[paraula];
            paraulesTrobades.push({
                paraula: paraula,
                valor: diccionariSentiments[paraula]
            });
        }
    }
    
    let sentiment = "neutral";
    let missatge = "Sentiment neutral";
    
    if (puntuacio > 2) {
        sentiment = "positiu";
        missatge = "😊 Sentiment molt positiu";
    } else if (puntuacio > 0) {
        sentiment = "positiu";
        missatge = "🙂 Sentiment positiu";
    } else if (puntuacio < -2) {
        sentiment = "negatiu";
        missatge = "😠 Sentiment molt negatiu";
    } else if (puntuacio < 0) {
        sentiment = "negatiu";
        missatge = "😐 Sentiment negatiu";
    }
    
    return {
        sentiment: sentiment,
        missatge: missatge,
        puntuacio: puntuacio,
        paraulesTrobades: paraulesTrobades
    };
}

function start() {
    document.getElementById("estat").innerText = "🎧 Escoltant...";
    document.getElementById("estat").className = "status";
    recognition.start();
}

recognition.onresult = e => {
    const textReconegut = e.results[0][0].transcript;
    document.getElementById("estat").innerText = "✅ Veu detectada";
    document.getElementById("resultat").innerText = textReconegut;
    
    // Analitzar sentiment
    const resultatAnalisi = analitzarSentiment(textReconegut);
    
    // Actualitzar visualització de sentiment
    const elementSentiment = document.getElementById("sentiment");
    elementSentiment.innerText = resultatAnalisi.missatge + " (Puntuació: " + resultatAnalisi.puntuacio + ")";
    elementSentiment.className = "sentiment-box " + resultatAnalisi.sentiment;
    
    // Mostrar paraules detectades
    if (resultatAnalisi.paraulesTrobades.length > 0) {
        let detalls = "Paraules detectades: ";
        resultatAnalisi.paraulesTrobades.forEach(p => {
            detalls += p.paraula + "(" + p.valor + ") ";
        });
        console.log(detalls);
    }
};

recognition.onerror = e => {
    document.getElementById("estat").innerText = "❌ Error: " + e.error;
    document.getElementById("estat").className = "status";
};
</script>

</body>
</html>
