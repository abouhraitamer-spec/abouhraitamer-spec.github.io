
<!DOCTYPE html>
<html lang="ca">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Robot Poeta Sentimental</title>
<style>
/* ================= ESTILS GENERALS ================= */
body {
    font-family: 'Georgia', serif;
    max-width: 800px;
    margin: 0 auto;
    padding: 20px;
    background-color: #f5f0e6;
    color: #333;
    background-image: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M11 18c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm48 25c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm-43-7c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm63 31c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM34 90c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm56-76c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM12 86c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm28-65c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm23-11c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm-6 60c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm29 22c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zM32 63c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm57-13c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm-9-21c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM60 91c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM35 41c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM12 60c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2z' fill='%23d4c4a8' fill-opacity='0.1' fill-rule='evenodd'/%3E%3C/svg%3E");
}

h1 { text-align: center; color: #5d4037; font-size: 2.5em; margin-bottom: 10px; }
.subtitle { text-align: center; color: #795548; font-style: italic; margin-bottom: 20px; }
.robot-icon { text-align: center; font-size: 3em; margin: 20px 0; transition: transform 0.3s ease-in-out; }
.robot-icon.talking { transform: scale(1.2) rotate(-5deg); }

button {
    background-color: #8d6e63; color: white; border: none; padding: 12px 24px;
    font-size: 16px; border-radius: 5px; cursor: pointer; display: inline-block;
    margin: 10px 5px; font-family: 'Georgia', serif; transition: background-color 0.3s;
}
button:hover { background-color: #6d4c41; }
button:disabled { background-color: #ccc; cursor: not-allowed; }
.btn-info { background-color: #4CAF50; }
.btn-info:hover { background-color: #388E3C; }

#estat {
    padding: 12px; border-radius: 8px; text-align: center; font-weight: bold;
    margin: 10px 0; font-style: italic; background-color: #fff3e0;
    transition: background-color 0.8s, color 0.8s;
}

.box {
    background-color: white; border-radius: 12px; padding: 20px;
    margin: 20px 0; border-left: 5px solid #8d6e63; box-shadow: 0 4px 10px rgba(0,0,0,0.08);
}

#divErrors {
    display: none; background-color: #ffebee; color: #c62828;
    border: 2px solid #ef9a9a; padding: 12px; border-radius: 8px;
    margin: 10px 0; text-align: center; font-weight: bold;
}

textarea {
    width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 8px;
    font-size: 16px; font-family: 'Georgia', serif; resize: vertical; box-sizing: border-box;
    margin-top: 10px;
}
textarea:focus { outline: none; border-color: #8d6e63; box-shadow: 0 0 5px rgba(141, 110, 99, 0.5); }

.sentiment-box {
    text-align: center; font-size: 1.2em; font-weight: bold; padding: 15px;
    border-radius: 10px; margin: 20px 0; transition: all 0.8s ease;
}

.positiu { background-color: #e8f5e9; color: #2e7d32; border: 2px solid #81c784; }
.negatiu { background-color: #ffebee; color: #c62828; border: 2px solid #ef9a9a; }
.neutral { background-color: #f3e5f5; color: #7b1fa2; border: 2px solid #ce93d8; }

.poema {
    font-style: italic; line-height: 1.8; text-align: center; padding: 20px;
    background-color: #fff; border-radius: 12px; border: 2px dashed #8d6e63; margin: 20px 0;
}
.poema .vers { margin: 10px 0; padding: 8px; opacity: 0; transition: opacity 0.5s ease, transform 0.3s ease; }
.poema .signatura { text-align: right; font-style: normal; font-weight: bold; color: #5d4037; margin-top: 20px; }

.controls { text-align: center; margin: 20px 0; }
#estilPoema { margin-top: 10px; padding: 8px; font-size: 16px; border-radius: 5px; border: 1px solid #ccc; }

/* ================= ESTILS DEL MODAL ================= */
.modal {
    display: none; /* Amagat per defecte */
    position: fixed; z-index: 1000; left: 0; top: 0;
    width: 100%; height: 100%; overflow: auto;
    background-color: rgba(0,0,0,0.6);
    backdrop-filter: blur(3px);
}

.modal-content {
    background-color: #fefefe;
    margin: 5% auto; padding: 30px;
    border: 1px solid #888;
    width: 85%; max-width: 650px;
    border-radius: 15px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    font-family: sans-serif;
    line-height: 1.6;
}

.modal-content h2 { color: #4CAF50; margin-top: 0; }
.modal-content h3 { color: #5d4037; border-bottom: 2px solid #eee; padding-bottom: 5px; }

.close-btn {
    color: #aaa; float: right; font-size: 28px; font-weight: bold; cursor: pointer;
}
.close-btn:hover, .close-btn:focus { color: black; text-decoration: none; }
</style>
</head>
<body>

<div class="robot-icon">🤖✍️</div>
<h1>Robot Poeta Sentimental</h1>
<div class="subtitle">Transformo les teves paraules en versos que senten</div>

<div class="controls">
    <button onclick="start()" id="btnParlar">🎤 Parla amb mi</button>
    <button onclick="reprodueixPoema()">🔊 Escolta el poema</button>
    <button onclick="obreModal()" class="btn-info">🤓 Com funciona?</button>
    <br><br>
    <label for="estilPoema">Estil de poema:</label>
    <select id="estilPoema">
        <option value="clàssic">Clàssic</option>
        <option value="modern">Modern</option>
        <option value="minimalista">Minimalista</option>
    </select>
</div>

<div id="divErrors"></div>

<div class="box">
    <p><strong>Estat del Robot:</strong></p>
    <div id="estat">🌬️ Esperant les teves paraules al vent...</div>
</div>

<div class="box">
    <p><strong>Escriu com et sents o dicta-ho amb el micròfon:</strong></p>
    <textarea id="textUsuari" rows="3" placeholder="Avui em sento feliç perquè fa un dia fantàstic..."></textarea>
    <div style="text-align: center;">
        <button onclick="processarTextUsuari()">✍️ Analitza i crea el poema</button>
    </div>
</div>

<div class="box">
    <p><strong>Anàlisi de sentiments:</strong></p>
    <div class="sentiment-box neutral" id="sentiment">
        Esperant les teves paraules...
    </div>
</div>

<div class="box">
    <p><strong>Poema generat:</strong></p>
    <div class="poema" id="poema">
        <div class="vers">El poeta robòtic espera</div>
        <div class="vers">les teves paraules al vent</div>
        <div class="vers">per transformar sentiments</div>
        <div class="vers">en versos d'argent.</div>
        <div class="signatura">— Robot Poeta</div>
    </div>
</div>

<div id="infoModal" class="modal">
  <div class="modal-content">
    <span class="close-btn" onclick="tancaModal()">&times;</span>
    <h2>🤖 Les entranyes del Robot: Com funciona?</h2>
    <p>Aquesta pàgina web combina tres tecnologies integrades directament als navegadors moderns (sense necessitat de servidors externs):</p>
    
    <h3>1. L'Orella: Reconeixement de Veu (Speech-to-Text)</h3>
    <p>Utilitza l'API <code>window.SpeechRecognition</code>. Quan parles pel micròfon, el navegador envia l'àudio als motors de reconeixement (sovint de Google o Apple) i ens retorna un text escrit. Funciona de manera asíncrona (espera fins que deixes de parlar).</p>

    <h3>2. El Cervell: Anàlisi de Sentiments (Lèxic)</h3>
    <p>El programa divideix la teva frase en paraules i les compara amb un <strong>Diccionari de Sentiments</strong> en el codi. Si troba la paraula <em>"feliç"</em> suma 3 punts. Si troba <em>"trist"</em> en resta 2. Finalment fa la suma i decideix si estàs positiu, neutral o negatiu per triar quin poema generar.</p>

    <h3>3. La Veu: Síntesi de Veu (Text-to-Speech o TTS)</h3>
    <p>Utilitza l'API <code>window.speechSynthesis</code>. Transforma el text generat en so sintètic.</p>
    
    <div style="background-color: #fff3cd; padding: 10px; border-left: 4px solid #ffc107; margin-top: 15px;">
        <strong>⚠️ Per què fallava abans el TTS? (El bloqueig del navegador)</strong><br>
        Abans, el poema intentava llegir-se després d'una animació (amb un retard de temps <code>setTimeout</code>). Actualment, els navegadors (Chrome, Safari, Edge) <strong>bloquegen qualsevol àudio automàtic</strong> per evitar anuncis molests. L'àudio NOMÉS pot sonar si està cridat exactament en el mateix moment en què l'usuari ha fet un "clic" actiu. La solució ha estat programar la lectura en l'instant precís del clic, i cancel·lar les veus anteriors amb <code>speechSynthesis.cancel()</code> per evitar que s'acumulin.
    </div>
  </div>
</div>

<script>
/* ================= LÒGICA JAVASCRIPT ================= */

// 1. DICCIONARI LÈXIC (El Cervell)
const diccionariSentiments = {
    "bo":2, "bé":2, "content":2, "feliç":3, "fantàstic":3, "alegria": 2, "meravellós": 3, "pau": 1, "genial": 3,
    "dolent":-2, "malament":-2, "trist":-2, "horrible":-3, "problema":-1, "fosc": -1, "plorar": -2, "enfadat": -3
};

let poemaActual = "";
let sintesisVeu = null;

// 2. RECONEIXEMENT DE VEU (L'Orella)
const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
let recognition = null;

if (SpeechRecognition) {
    recognition = new SpeechRecognition();
    recognition.lang = "ca-ES";
    recognition.continuous = false;
    recognition.interimResults = false;

    recognition.onstart = function() {
        mostrarError(""); 
        document.getElementById("estat").innerText = "🎧 T'estic escoltant... Parla ara.";
    };

    recognition.onresult = function(e){
        const textDictat = e.results[0][0].transcript;
        document.getElementById("estat").innerText = "✅ Veu detectada i transcrita.";
        document.getElementById("textUsuari").value = textDictat;
        processarLleiMot(textDictat);
    };

    recognition.onerror = function(e){
        let missatgeError = "S'ha produït un error desconegut.";
        if (e.error === 'no-speech') missatgeError = "No he sentit res. Torna-ho a provar.";
        if (e.error === 'audio-capture') missatgeError = "No s'ha trobat cap micròfon.";
        if (e.error === 'not-allowed') missatgeError = "Has denegat el permís per usar el micròfon.";
        
        mostrarError("❌ Error de micròfon: " + missatgeError);
        document.getElementById("estat").innerText = "⚠️ La connexió vocal s'ha interromput.";
    };

    recognition.onend = function() {
        if(document.getElementById("estat").innerText.includes("escoltant")) {
            document.getElementById("estat").innerText = "🌬️ Esperant les teves paraules...";
        }
    }
} else {
    document.getElementById("btnParlar").disabled = true;
    mostrarError("El teu navegador no suporta el reconeixement de veu. Fes servir el quadre de text.");
}

// 3. GESTIÓ DE LA INTERFÍCIE
function mostrarError(missatge) {
    const div = document.getElementById("divErrors");
    if (missatge) {
        div.innerText = missatge;
        div.style.display = "block";
    } else {
        div.style.display = "none";
    }
}

function processarTextUsuari() {
    const text = document.getElementById("textUsuari").value.trim();
    if (!text) {
        mostrarError("Si us plau, escriu o dicta alguna cosa abans de crear el poema.");
        return;
    }
    mostrarError(""); 
    document.getElementById("estat").innerText = "🧠 Pensant i rimant...";
    processarLleiMot(text);
}

// 4. PROCÉS PRINCIPAL
function processarLleiMot(text) {
    const puntuacio = analitzarSentiment(text);
    const estil = document.getElementById("estilPoema").value;

    const elemS = document.getElementById("sentiment");
    let cls="neutral", txt="😐 Sentiment neutral";
    if(puntuacio >= 3){cls="positiu"; txt="✨ Sentiment molt positiu";}
    else if(puntuacio > 0){cls="positiu"; txt="😊 Sentiment positiu";}
    else if(puntuacio < -2){cls="negatiu"; txt="😢 Sentiment molt negatiu";}
    else if(puntuacio < 0){cls="negatiu"; txt="😔 Sentiment negatiu";}
    
    txt += ` (Puntuació total: ${puntuacio})`;
    elemS.innerText = txt;
    elemS.className = "sentiment-box " + cls;

    poemaActual = generarPoema(text, puntuacio, estil);

    // Dibuixar el poema amb HTML i animació CSS
    const linies = poemaActual.split('\n');
    let htmlPoema = '';
    linies.forEach(l => {
        if(l.trim() === '') htmlPoema += '<div style="height:10px;"></div>';
        else if(l.startsWith('—')) htmlPoema += '<div class="signatura">' + l + '</div>';
        else htmlPoema += '<div class="vers">' + l + '</div>';
    });
    
    const elemPoema = document.getElementById("poema");
    elemPoema.innerHTML = htmlPoema;

    const versosEls = elemPoema.querySelectorAll('.vers');
    versosEls.forEach((v, i) => setTimeout(() => v.style.opacity = 1, i * 300));

    // CORRECCIÓ CLAU: Crida directa al TTS just al moment del clic/reconeixement (sense setTimeouts llargs)
    parla(poemaActual);
}

function start() {
    if (recognition) {
        try { recognition.start(); } catch(e) { console.log("El reconeixement ja estava iniciat."); }
    }
}

// 5. SÍNTESI DE VEU (La Veu)
function parla(text) {
    // 1. Cancel·lem qualsevol veu que estigui parlant actualment
    window.speechSynthesis.cancel();
    
    sintesisVeu = new SpeechSynthesisUtterance(text);
    sintesisVeu.lang = "ca-ES"; 
    sintesisVeu.rate = 0.9; 
    sintesisVeu.pitch = 1.0; 
    sintesisVeu.volume = 1.0;

    sintesisVeu.onstart = () => {
        document.getElementById("estat").innerText = "🔊 El poema flueix com riu de llum...";
        document.querySelector('.robot-icon').classList.add('talking');
    };
    sintesisVeu.onend = () => {
        document.getElementById("estat").innerText = "✅ Poema recitat amb l'ànima";
        document.querySelector('.robot-icon').classList.remove('talking');
    };
    sintesisVeu.onerror = (e) => {
        console.error("Error en la síntesi de veu", e);
        document.querySelector('.robot-icon').classList.remove('talking');
    };
    
    // 2. Executem la veu immediatament
    window.speechSynthesis.speak(sintesisVeu);
}

function reprodueixPoema() {
    if (poemaActual) parla(poemaActual);
    else mostrarError("Encara no has creat cap poema. Escriu o dicta alguna cosa primer.");
}

function analitzarSentiment(text) {
    const paraules = text.toLowerCase().replace(/[.,!?;:]/g, '').split(/\s+/);
    let puntuacio = 0;
    for (const paraula of paraules) {
        if(diccionariSentiments[paraula]) {
            puntuacio += diccionariSentiments[paraula];
        }
    }
    return puntuacio;
}

function generarPoema(text, puntuacio, estil) {
    let versos = [], titol = "";
    
    if (puntuacio >= 3) {
        titol = "Oda a l'Alegria"; 
        versos = ["El sol dansa al teu cor,", "el vent canta amb tu,", "riu de llum s'estén,", "i la teva ànima brilla."];
    } else if (puntuacio >= 1) {
        titol = "Sonet del Benestar"; 
        versos = ["La calma flueix,", "un sospir suau recorre el dia,", "tot sembla més lleu,", "i el moment és música."];
    } else if (puntuacio >= -1) {
        titol = "Balada del Present"; 
        versos = ["Les paraules flueixen suaus,", "ni gran goig ni clots,", "un equilibri precís", "en el silenci amable."];
    } else if (puntuacio >= -3) {
        titol = "Elegia del Desassossec"; 
        versos = ["Sento una ombra en el teu dir,", "fred suau que toca el cor,", "però la llum espera,", "i torna a guiar el teu pas."];
    } else {
        titol = "Càntic de la Melangia"; 
        versos = ["Com pluja persistent,", "la tristesa mulla el parlar,", "però el sol sempre torna,", "i amb ell, l'esperança brilla."];
    }
    
    let prefix = (puntuacio > 2) ? "☀️ " : (puntuacio < -2) ? "🌧️ " : "";
    return prefix + titol + "\n\n" + versos.join("\n") + "\n\n— Robot Poeta";
}

// 6. FUNCIONS DEL MODAL
const modal = document.getElementById("infoModal");

function obreModal() {
    modal.style.display = "block";
}

function tancaModal() {
    modal.style.display = "none";
}

// Tancar el modal si fem clic fora de la caixa blanca
window.onclick = function(event) {
    if (event.target == modal) {
        modal.style.display = "none";
    }
}
</script>
</body>
</html>









